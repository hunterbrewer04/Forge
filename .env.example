# Ably (real-time messaging — server-side only)
ABLY_API_KEY=your-ably-api-key

# Cloudflare R2 (media storage — server-side only)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=forge-media
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# Upstash Redis (optional — falls back to in-memory rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Web Push / VAPID (optional — push notifications disabled without these)
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com
